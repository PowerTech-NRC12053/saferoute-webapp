@startuml
scale 0.5
skinparam monochrome false

class "«Component»\nApp" as App {
  -currentUser: Object
  -isAuthenticated: Boolean
  -currentRoute: String
  -- methods --
  +handleLogin(user: Object): void
  +handleLogout(): void
  +navigateTo(route: String): void
  +updateCurrentUser(user: Object): void
}

package "notifications" {
  package "domain.model" {
    class "Notification" as NotificationModel {
      -id: String
      -parentId: String
      -tripId: String
      -category: String
      -deliveryState: String
      -message: String
      -sentAt: String
    }
    class "Alert" as AlertModel {
      -id: String
      -triggeredAt: String
    }
    class "Announcement" as AnnouncementModel {
      -id: String
      -routeId: String
      -message: String
      -publishedAt: String
    }
  }
  package "presentation.components" {
    class "«Component»\nNotificationList" as NotificationList {
      -notifications: Array
      -unreadCount: Number
      -- methods --
      +markAsRead(notificationId: String): void
      +filterByCategory(category: String): Array
      +getUnreadCount(): Number
      -- emits --
      +notification-read(notificationId: String)
    }

    class "«Component»\nAlertPanel" as AlertPanel {
      -alerts: Array
      -hasActivePanic: Boolean
      -- methods --
      +triggerPanic(): void
      +dismissAlert(alertId: String): void
      +hasActivePanic(): Boolean
      -- emits --
      +panic-triggered()
      +alert-dismissed(alertId: String)
    }

    class "«Component»\nAnnouncementForm" as AnnouncementForm {
      -message: String
      -routeId: String
      -errorMessage: String
      -- methods --
      +submitAnnouncement(): void
      +clearFields(): void
      +validateForm(): Boolean
      -- emits --
      +announcement-published(announcement: Object)
    }
  }
}

App *-down-> NotificationList : contains
App *-down-> AlertPanel : contains
App *-down-> AnnouncementForm : contains
NotificationList -up-> App : emits notification-read
AlertPanel -up-> App : emits panic-triggered
AnnouncementForm -up-> App : emits announcement-published
NotificationList --> NotificationModel : uses
AlertPanel --> AlertModel : uses
AnnouncementForm --> AnnouncementModel : uses
NotificationModel *--> AlertModel : triggers
NotificationModel *--> AnnouncementModel : includes

@enduml
