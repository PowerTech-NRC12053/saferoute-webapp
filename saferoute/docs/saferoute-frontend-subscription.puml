@startuml
skinparam monochrome false

class "«Component»\nApp" as App {
  -currentUser: Object
  -isAuthenticated: Boolean
  -currentRoute: String
  -- methods --
  +handleLogin(user: Object): void
  +handleLogout(): void
  +navigateTo(route: String): void
  +updateCurrentUser(user: Object): void
}

package "subscription" {
  package "domain.model" {
    class "Subscription" as SubModel {
      -id: String
      -planTier: String
      -state: String
      -startDate: String
      -endDate: String
    }
    class "Plan" as PlanModel {
      -id: Number
      -planTier: String
      -routeQuota: Number
      -driverQuota: Number
      -price: Number
    }
  }
  package "presentation.components" {
    class "«Component»\nPlanSelector" as PlanSelector {
      -plans: Array
      -selectedPlan: Object
      -errorMessage: String
      -- methods --
      +selectPlan(plan: Object): void
      +confirmSelection(): void
      +clearSelection(): void
      -- emits --
      +plan-selected(plan: Object)
    }

    class "«Component»\nSubscriptionStatus" as SubscriptionStatus {
      +subscription: Object
      +plan: Object
      -- methods --
      +getStatusLabel(): String
      +getRemainingDays(): Number
      +isActive(): Boolean
      -- emits --
      +upgrade-requested()
      +cancel-requested()
    }
  }
}

App *-down-> PlanSelector : contains
App *-down-> SubscriptionStatus : contains
PlanSelector -up-> App : emits plan-selected
SubscriptionStatus -up-> App : emits upgrade-requested
PlanSelector --> PlanModel : uses
SubscriptionStatus --> SubModel : uses
SubModel --> PlanModel : has

@enduml
