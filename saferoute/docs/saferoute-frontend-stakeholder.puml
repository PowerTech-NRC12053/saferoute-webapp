@startuml
skinparam monochrome false

class "«Component»\nApp" as App {
  -currentUser: Object
  -isAuthenticated: Boolean
  -currentRoute: String
  -- methods --
  +handleLogin(user: Object): void
  +handleLogout(): void
  +navigateTo(route: String): void
  +updateCurrentUser(user: Object): void
}

package "stakeholder" {
  package "domain.model" {
    class "Parent" as ParentModel {
      -id: String
      -firstName: String
      -lastName: String
      -email: String
      -phoneNumber: String
      -children: Array
    }
    class "Driver" as DriverModel {
      -id: String
      -firstName: String
      -lastName: String
      -email: String
      -phoneNumber: String
      -licenseNumber: String
    }
    class "Child" as ChildModel {
      -id: String
      -firstName: String
      -lastName: String
      -age: Number
      -enrollmentState: String
    }
    class "StudentGroup" as StudentGroupModel {
      -id: String
      -name: String
      -children: Array
    }
  }
  package "presentation.components" {
    class "«Component»\nParentList" as ParentList {
      -parents: Array
      -searchQuery: String
      -- methods --
      +filterParents(): Array
      +selectParent(parent: Object): void
      +deleteParent(parentId: String): void
      -- emits --
      +parent-selected(parent: Object)
      +parent-deleted(parentId: String)
    }

    class "«Component»\nDriverList" as DriverList {
      -drivers: Array
      -searchQuery: String
      -- methods --
      +filterDrivers(): Array
      +selectDriver(driver: Object): void
      +deleteDriver(driverId: String): void
      -- emits --
      +driver-selected(driver: Object)
      +driver-deleted(driverId: String)
    }

    class "«Component»\nChildList" as ChildList {
      -children: Array
      -searchQuery: String
      -- methods --
      +filterChildren(): Array
      +selectChild(child: Object): void
      +deleteChild(childId: String): void
      -- emits --
      +child-selected(child: Object)
      +child-deleted(childId: String)
    }

    class "«Component»\nStudentGroupList" as StudentGroupList {
      -groups: Array
      -searchQuery: String
      -- methods --
      +filterGroups(): Array
      +selectGroup(group: Object): void
      +finalizeGroup(groupId: String): void
      -- emits --
      +group-selected(group: Object)
      +group-finalized(groupId: String)
    }
  }
}

App *-down-> ParentList : contains
App *-down-> DriverList : contains
App *-down-> ChildList : contains
App *-down-> StudentGroupList : contains
ParentList -up-> App : emits parent-selected
DriverList -up-> App : emits driver-selected
ChildList -up-> App : emits child-selected
StudentGroupList -up-> App : emits group-selected
ParentList --> ParentModel : uses
DriverList --> DriverModel : uses
ChildList --> ChildModel : uses
StudentGroupList --> StudentGroupModel : uses
ParentModel *--> ChildModel : has

@enduml
