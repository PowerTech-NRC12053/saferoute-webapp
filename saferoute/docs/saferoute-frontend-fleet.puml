@startuml
scale 0.5
skinparam monochrome false

class "«Component»\nApp" as App {
  -currentUser: Object
  -isAuthenticated: Boolean
  -currentRoute: String
  -- methods --
  +handleLogin(user: Object): void
  +handleLogout(): void
  +navigateTo(route: String): void
  +updateCurrentUser(user: Object): void
}

package "fleet" {
  package "domain.model" {
    class "Route" as RouteModel {
      -id: String
      -name: String
      -routeState: String
      -departureTime: String
      -serviceDays: Array
      -stops: Array
    }
    class "Stop" as StopModel {
      -id: String
      -name: String
      -coordinates: Object
      -stopOrder: Number
    }
    class "Vehicle" as VehicleModel {
      -id: String
      -plate: String
      -model: String
      -brand: String
      -capacity: Number
    }
    class "Assignment" as AssignmentModel {
      -id: String
      -driverId: String
      -children: Array
    }
  }
  package "presentation.components" {
    class "«Component»\nRouteForm" as RouteForm {
      -name: String
      -departureTime: String
      -serviceDays: Array
      -stops: Array
      -errorMessage: String
      -- methods --
      +submitRoute(): void
      +addStop(stop: Object): void
      +removeStop(stopId: String): void
      +validateForm(): Boolean
      -- emits --
      +route-created(route: Object)
      +route-updated(route: Object)
    }

    class "«Component»\nStopList" as StopList {
      -stops: Array
      -selectedStop: Object
      -- methods --
      +reorderStops(stops: Array): void
      +selectStop(stop: Object): void
      +removeStop(stopId: String): void
      -- emits --
      +stop-selected(stop: Object)
      +stop-removed(stopId: String)
      +stops-reordered(stops: Array)
    }

    class "«Component»\nVehicleList" as VehicleList {
      -vehicles: Array
      -searchQuery: String
      -- methods --
      +filterVehicles(): Array
      +selectVehicle(vehicle: Object): void
      +deleteVehicle(vehicleId: String): void
      -- emits --
      +vehicle-selected(vehicle: Object)
      +vehicle-deleted(vehicleId: String)
    }

    class "«Component»\nAssignmentForm" as AssignmentForm {
      -selectedDriver: Object
      -selectedChildren: Array
      -errorMessage: String
      -- methods --
      +assignDriver(driver: Object): void
      +addChild(child: Object): void
      +removeChild(childId: String): void
      +submitAssignment(): void
      -- emits --
      +assignment-submitted(assignment: Object)
      +assignment-cleared()
    }
  }
}

App *-down-> RouteForm : contains
App *-down-> StopList : contains
App *-down-> VehicleList : contains
App *-down-> AssignmentForm : contains
RouteForm -up-> App : emits route-created
AssignmentForm -up-> App : emits assignment-submitted
VehicleList -up-> App : emits vehicle-selected
RouteForm --> RouteModel : uses
StopList --> StopModel : uses
VehicleList --> VehicleModel : uses
AssignmentForm --> AssignmentModel : uses
RouteModel *--> StopModel : has

@enduml
