@startuml
skinparam monochrome false

class "«Component»\nApp" as App {
  -currentUser: Object
  -isAuthenticated: Boolean
  -currentRoute: String
  -- methods --
  +handleLogin(user: Object): void
  +handleLogout(): void
  +navigateTo(route: String): void
  +updateCurrentUser(user: Object): void
}

package "iam" {
  package "domain.model" {
    class "User" as IamUser {
      -id: String
      -firstName: String
      -lastName: String
      -email: String
      -role: String
      -organizationId: String
    }
    class "Organization" as OrgModel {
      -id: String
      -name: String
      -status: String
      -createdAt: String
    }
  }
  package "presentation.components" {
    class "«Component»\nAdminLoginForm" as AdminLoginForm {
      -email: String
      -password: String
      -errorMessage: String
      -- methods --
      +submitLogin(): void
      +clearFields(): void
      +validateForm(): Boolean
      -- emits --
      +admin-logged-in(user: Object)
      +login-failed(error: String)
    }

    class "«Component»\nAdminRegisterForm" as AdminRegisterForm {
      -firstName: String
      -lastName: String
      -email: String
      -password: String
      -confirmPassword: String
      -errorMessage: String
      -- methods --
      +submitRegister(): void
      +clearFields(): void
      +validateForm(): Boolean
      +passwordsMatch(): Boolean
      -- emits --
      +admin-registered(user: Object)
      +registration-failed(error: String)
    }

    class "«Component»\nUserLoginForm" as UserLoginForm {
      -email: String
      -password: String
      -errorMessage: String
      -- methods --
      +submitLogin(): void
      +clearFields(): void
      +validateForm(): Boolean
      -- emits --
      +user-logged-in(user: Object)
      +login-failed(error: String)
    }

    class "«Component»\nOrganizationForm" as OrganizationForm {
      -name: String
      -errorMessage: String
      -- methods --
      +submitOrganization(): void
      +clearFields(): void
      +validateForm(): Boolean
      -- emits --
      +organization-created(organization: Object)
      +organization-updated(organization: Object)
    }

    class "«Component»\nOrganizationProfile" as OrganizationProfile {
      +organization: Object
      -- methods --
      +getStatusLabel(): String
      +isActive(): Boolean
      -- emits --
      +edit-requested()
      +suspend-requested()
    }
  }
}

App *-down-> AdminLoginForm : contains
App *-down-> AdminRegisterForm : contains
App *-down-> UserLoginForm : contains
App *-down-> OrganizationForm : contains
App *-down-> OrganizationProfile : contains
AdminLoginForm -up-> App : emits admin-logged-in
AdminRegisterForm -up-> App : emits admin-registered
UserLoginForm -up-> App : emits user-logged-in
OrganizationForm -up-> App : emits organization-created
OrganizationProfile -up-> App : emits edit-requested
AdminLoginForm --> IamUser : uses
AdminRegisterForm --> IamUser : uses
UserLoginForm --> IamUser : uses
OrganizationForm --> OrgModel : uses
OrganizationProfile --> OrgModel : uses
IamUser --> OrgModel : belongs to

@enduml
