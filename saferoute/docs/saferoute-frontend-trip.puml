@startuml
skinparam monochrome false

class "«Component»\nApp" as App {
  -currentUser: Object
  -isAuthenticated: Boolean
  -currentRoute: String
  -- methods --
  +handleLogin(user: Object): void
  +handleLogout(): void
  +navigateTo(route: String): void
  +updateCurrentUser(user: Object): void
}

package "trip" {
  package "domain.model" {
    class "Trip" as TripModel {
      -id: String
      -routeId: String
      -driverId: String
      -tripState: String
      -startTime: String
      -endTime: String
      -attendances: Array
      -incidents: Array
    }
    class "Attendance" as AttendanceModel {
      -id: String
      -childId: String
      -boardingState: String
      -boardedAt: String
    }
    class "Incident" as IncidentModel {
      -id: String
      -routeId: String
      -description: String
      -reportedAt: String
    }
  }
  package "presentation.components" {
    class "«Component»\nTripDashboard" as TripDashboard {
      -trip: Object
      -tripState: String
      -- methods --
      +startTrip(): void
      +completeTrip(): void
      +getTripState(): String
      +getAttendanceSummary(): Array
      -- emits --
      +trip-started(trip: Object)
      +trip-completed(trip: Object)
    }

    class "«Component»\nAttendanceChecklist" as AttendanceChecklist {
      -attendances: Array
      -pendingCount: Number
      -- methods --
      +updateBoardingState(childId: String, state: String): void
      +getPendingCount(): Number
      +isAllBoarded(): Boolean
      -- emits --
      +boarding-updated(attendance: Object)
    }

    class "«Component»\nIncidentForm" as IncidentForm {
      -description: String
      -errorMessage: String
      -- methods --
      +submitIncident(): void
      +clearFields(): void
      +validateForm(): Boolean
      -- emits --
      +incident-reported(incident: Object)
    }
  }
}

App *-down-> TripDashboard : contains
App *-down-> AttendanceChecklist : contains
App *-down-> IncidentForm : contains
TripDashboard -up-> App : emits trip-started
TripDashboard -up-> App : emits trip-completed
AttendanceChecklist -up-> App : emits boarding-updated
IncidentForm -up-> App : emits incident-reported
TripDashboard --> TripModel : uses
AttendanceChecklist --> AttendanceModel : uses
IncidentForm --> IncidentModel : uses
TripModel *--> AttendanceModel : tracks
TripModel *--> IncidentModel : records

@enduml
